# ── Auth ──────────────────────────────────────────────────────────────────────
# Supabase Auth handles email + password. No Twilio. No OTP. No phone.
#
# Configure in Supabase Dashboard → Authentication:
#   - Auth → Providers → Email → Enable email sign-ins (on by default)
#   - Auth → Email Templates → customise confirmation email
#   - Auth → URL Configuration → set Site URL to NEXT_PUBLIC_APP_URL
#   - Auth → URL Configuration → add /api/auth/callback to Redirect URLs

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_POSTING=false
NEXT_PUBLIC_ENABLE_MAPS=false
